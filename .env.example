# ── BMOWA live data backend (Google Sheets via service account) ──────────────
# Copy this file to .env.local and fill in the values. NEVER commit .env.local.
# See docs/google-backend-setup.md for how to obtain these.

# The live-data Google Sheet ID (the long string in the sheet URL between /d/ and /edit).
# Defaults in code to the sheet created under Malgudi Committee 2026-27 / Zero Final /
# BMOWA_WebApp_Live_DataSource, so this is optional unless you point at a different sheet.
GOOGLE_SHEET_ID=1_wVJu9SgyuJN97K-zgnYs3PWFX95gX7LOGM5ardWbF4

# The ENTIRE service-account JSON key, on one line (paste the whole file content).
# Example shape (do not use these values):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"bmowa-app@...iam.gserviceaccount.com",...}
GOOGLE_SERVICE_ACCOUNT_JSON=
